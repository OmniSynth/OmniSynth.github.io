---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import Announcement from '~/components/widgets/Announcement.astro';
import { getHeaderData, getFooterData } from '~/navigation';
import { defaultLocale, type Locale } from '~/i18n/ui';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
  postI18n?: { zh?: string; en?: string } | null;
}

const { metadata, postI18n = null } = Astro.props;
const locale = (Astro.currentLocale as Locale | undefined) || defaultLocale;
const headerData = getHeaderData(locale);
const footerData = getFooterData(locale);
---

<Layout metadata={metadata} postI18n={postI18n}>
  <slot name="announcement">
    <Announcement locale={locale} />
  </slot>
  <slot name="header">
    <Header {...headerData} locale={locale} isSticky showRssFeed showToggleTheme />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>
</Layout>
