---
import Layout from '~/layouts/Layout.astro';
import { defaultLocale, localizePath, type Locale } from '~/i18n/ui';

const title = `Error 404`;
const locale = (Astro.currentLocale as Locale | undefined) || defaultLocale;
---

<Layout metadata={{ title }}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">Error</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">页面不存在 / Page not found</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          回到首页继续了解 Omni Synth / Return home to continue with Omni Synth.
        </p>
        <a rel="noopener noreferrer" href={localizePath('/', locale)} class="btn ml-4">首页 / Home</a>
      </div>
    </div>
  </section>
</Layout>
