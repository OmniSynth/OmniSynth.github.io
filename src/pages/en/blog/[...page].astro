---
import type { GetStaticPaths, InferGetStaticPropsType, PaginateFunction } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import BlogListPage from '~/components/blog/BlogListPage.astro';

import { blogListRobots, blogPostsPerPage, fetchPostsByLocale, isBlogEnabled, isBlogListRouteEnabled } from '~/utils/blog';
import { useTranslations } from '~/i18n/ui';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }: { paginate: PaginateFunction }) => {
  if (!isBlogEnabled || !isBlogListRouteEnabled) return [];
  return paginate(await fetchPostsByLocale('en'), {
    pageSize: blogPostsPerPage,
  });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;
const locale = 'en' as const;
const t = useTranslations(locale);

const title =
  currentPage > 1
    ? `${t('blog.pageTitle')}${t('blog.pageSuffix').replace('{page}', String(currentPage))}`
    : t('blog.pageTitle');

const metadata = {
  title,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <BlogListPage
    locale={locale}
    posts={page.data}
    currentPage={currentPage}
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
  />
</Layout>
