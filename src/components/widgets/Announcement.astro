---
import { Icon } from 'astro-icon/components';
import { useTranslations, type Locale } from '~/i18n/ui';
import { formatStarCount, getOmniSynthOrgStars } from '~/utils/github';

export interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? ((Astro.currentLocale as Locale | undefined) || 'zh');
const t = useTranslations(locale);
const orgStars = await getOmniSynthOrgStars();
const starsLabel = formatStarCount(orgStars, locale === 'zh' ? 'zh-CN' : 'en');
---

<div
  id="announcement-bar"
  data-announcement
  class="announcement-bar text-sm bg-slate-900 text-slate-300 dark:bg-transparent dark:border-b dark:border-slate-800 dark:text-slate-400 items-center gap-2 overflow-hidden pl-3 pr-5 py-2 relative text-ellipsis whitespace-nowrap"
>
  <span
    class="bg-white/20 dark:bg-slate-700 text-slate-100 dark:text-slate-300 font-semibold px-1 py-0.5 text-xs shrink-0 inline-block"
    >{t('announcement.badge')}</span
  >
  <a
    href="https://github.com/OmniSynth"
    target="_blank"
    rel="noopener noreferrer"
    class="text-slate-300 hover:underline dark:text-slate-400 font-medium min-w-0 truncate"
  >
    {t('announcement.text')}
  </a>
  <a
    target="_blank"
    rel="noopener noreferrer"
    class="ml-auto shrink-0 inline-flex items-center gap-1 rounded-md bg-white px-2 py-0.5 text-xs font-semibold text-slate-800 shadow-sm hover:bg-slate-100"
    title={t('announcement.starsTitle')}
    href="https://github.com/OmniSynth"
  >
    <Icon name="tabler:star-filled" class="w-3.5 h-3.5 text-amber-500" />
    <span>Stars</span>
    <span
      data-org-stars
      data-stars-locale={locale}
      class="min-w-[1.25rem] text-center tabular-nums text-slate-900">{starsLabel}</span
    >
  </a>
  <button
    type="button"
    data-announcement-close
    class="shrink-0 relative z-10 inline-flex items-center justify-center w-7 h-7 rounded-md text-slate-300 hover:text-white hover:bg-white/10 dark:text-slate-400 dark:hover:text-white dark:hover:bg-slate-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
    aria-label={t('announcement.close')}
    title={t('announcement.close')}
  >
    <Icon name="tabler:x" class="w-4 h-4" />
  </button>
</div>

<script is:inline>
  async function refreshOrgStars() {
    const el = document.querySelector('[data-org-stars]');
    if (!el) return;

    try {
      let page = 1;
      let total = 0;
      while (page <= 20) {
        const res = await fetch(
          `https://api.github.com/orgs/OmniSynth/repos?per_page=100&page=${page}&type=public`,
          {
            headers: {
              Accept: 'application/vnd.github+json',
              'User-Agent': 'OmniSynth-website',
            },
          }
        );
        if (!res.ok) break;
        const repos = await res.json();
        if (!Array.isArray(repos) || repos.length === 0) break;
        total += repos.reduce((sum, repo) => sum + (repo.stargazers_count || 0), 0);
        if (repos.length < 100) break;
        page += 1;
      }

      const locale = el.getAttribute('data-stars-locale') === 'zh' ? 'zh-CN' : 'en';
      el.textContent = new Intl.NumberFormat(locale, {
        notation: total >= 10000 ? 'compact' : 'standard',
      }).format(total);
    } catch (_) {
      /* keep build-time value */
    }
  }

  refreshOrgStars();
  document.addEventListener('astro:after-swap', refreshOrgStars);
  document.addEventListener('astro:page-load', refreshOrgStars);
</script>
